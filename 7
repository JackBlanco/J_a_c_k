<html>
<head>
<title> Lab 6 Blanco </title>

<style>

h1{
display:flex;
justify-content:center;
}

body{
text-align:center;
}

table{
margin-left:17%;
width:66%;
text-align:center;
}

</style>

</head>

<body>

<h1>Inventory System</h1>

<input type="text" class="itemname" placeholder="Item Name">
<input type="text" class="price" placeholder="Price">
<input type="text" class="stock" placeholder="Stock">

<button onclick="additems()"> Add Item </button>

<br><br>

<input type="text" class="buyname" placeholder="Item to Buy">
<input type="text" class="buyqty" placeholder="Quantity">

<button onclick="buyitem()"> Buy Item </button>

<br><br>

<table border="1" class="table">

<tr>
<th>Item</th>
<th>Price</th>
<th>Stock</th>
</tr>

<tr>
<td>Apple</td>
<td>10.00</td>
<td>5</td>
</tr>

<tr>
<td>Banana</td>
<td>5.00</td>
<td><font color="red">Out Of Stock</font></td>
</tr>

<tr>
<td>Orange</td>
<td>8.50</td>
<td>3</td>
</tr>

<tr>
<td>Strawberry</td>
<td>15.00</td>
<td>20</td>
</tr>

<tr>
<td>Guava</td>
<td>12</td>
<td>5</td>
</tr>

</table>

<script>

function additems(){

let name = document.querySelector(".itemname").value;
let price = document.querySelector(".price").value;
let stock = document.querySelector(".stock").value;

let table = document.querySelector(".table");

let row = document.createElement("tr");

let cell1 = document.createElement("td");
let cell2 = document.createElement("td");
let cell3 = document.createElement("td");

cell1.innerHTML = name;
cell2.innerHTML = price;

if(stock == 0){
cell3.innerHTML = "Out Of Stock";
cell3.style.color = "red";
}
else{
cell3.innerHTML = stock;
}

row.appendChild(cell1);
row.appendChild(cell2);
row.appendChild(cell3);

table.appendChild(row);

}


function buyitem(){

let name = document.querySelector(".buyname").value;
let qty = parseInt(document.querySelector(".buyqty").value);

let table = document.querySelector(".table");

let rows = table.getElementsByTagName("tr");

for(let i=1;i<rows.length;i++){

let item = rows[i].cells[0].innerHTML;
let stock = rows[i].cells[2].innerHTML;

if(item == name){

if(stock == "Out Of Stock"){
alert("Item is out of stock");
return;
}

let newstock = parseInt(stock) - qty;

if(newstock <= 0){
rows[i].cells[2].innerHTML = "Out Of Stock";
rows[i].cells[2].style.color = "red";
}
else{
rows[i].cells[2].innerHTML = newstock;
}

}

}

}

</script>

</body>
</html>
